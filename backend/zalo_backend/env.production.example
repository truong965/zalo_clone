# Production Environment Variables for Zalo Clone Backend
# Copy this file to .env.production on EC2 and fill in all values
# Storage: AWS S3 (bucket: zalo-clone-media-production)
# Queue:   AWS SQS
# Auth:    IAM Instance Profile on EC2 — no AWS_ACCESS_KEY_ID/SECRET needed

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=zalo_prod_user
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password
POSTGRES_DB=zalo_clone_prod_db
# Constructed from above — used by prisma migrate deploy in CI/CD
DATABASE_URL=postgresql://zalo_prod_user:CHANGE_ME_strong_postgres_password@postgres:5432/zalo_clone_prod_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── JWT ── app reads ACCESS + REFRESH secrets separately, NOT JWT_SECRET ──────
JWT_ACCESS_SECRET=CHANGE_ME_very_long_access_secret_minimum_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_very_long_refresh_secret_minimum_64_chars
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=100d

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Bucket must be pre-created in AWS Console (ap-southeast-1).
# See doc/plan/MINIO-BULL-TO-S3-SQS-MIGRATION.md for bucket/IAM setup steps.
# S3_ENDPOINT is intentionally absent — SDK routes to native AWS S3.
# AWS credentials are resolved from the EC2 IAM Instance Profile automatically.
# DO NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY on EC2 with Instance Profile.
S3_BUCKET_NAME=zalo-clone-media-production
AWS_REGION=ap-southeast-1
# CloudFront CDN domain (Phase 3 — leave empty until CloudFront is configured)
CLOUDFRONT_DOMAIN=

# ── AWS SQS ───────────────────────────────────────────────────────────────────
# Queues must be pre-created. Replace <account-id> with your AWS account ID.
# See doc/plan/MINIO-BULL-TO-S3-SQS-MIGRATION.md Phase 2 for queue setup steps.
QUEUE_PROVIDER=sqs
SQS_IMAGE_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/<account-id>/zalo-media-image-queue
SQS_IMAGE_DLQ_URL=https://sqs.ap-southeast-1.amazonaws.com/<account-id>/zalo-media-image-dlq
SQS_VIDEO_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/<account-id>/zalo-media-video-queue
SQS_VIDEO_DLQ_URL=https://sqs.ap-southeast-1.amazonaws.com/<account-id>/zalo-media-video-dlq
SQS_VISIBILITY_TIMEOUT_IMAGE=120
SQS_VISIBILITY_TIMEOUT_VIDEO=900
SQS_WAIT_TIME=20
# AWS credentials for SQS are resolved automatically via IAM Instance Profile (ZaloSQSAccess).
# Do NOT set SQS_AWS_ACCESS_KEY_ID / SQS_AWS_SECRET_ACCESS_KEY.

# ── WebRTC / TURN Server ──────────────────────────────────────────────────────
STUN_SERVER_URL=stun:stun.l.google.com:19302
# Replace with your EC2 public IP: turn:<EC2_PUBLIC_IP>:3478
TURN_SERVER_URL=turn:54.151.156.72:3478
TURN_SECRET=CHANGE_ME_strong_turn_secret
TURN_CREDENTIAL_TTL=43200

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Comma-separated if multiple origins
CORS_ORIGINS=http://54.151.156.72
FRONTEND_URL=http://54.151.156.72

# ── Firebase Push Notifications ───────────────────────────────────────────────
FIREBASE_PROJECT_ID=zalo-clone-d00f3
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@zalo-clone-d00f3.iam.gserviceaccount.com
# Copy FIREBASE_PRIVATE_KEY exactly from .env.development.local (keep quotes + \n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Security / Misc ───────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
LOG_LEVEL=info
