/**
 * Model: CallHistory [NEW]
 * Lưu lịch sử cuộc gọi (write on CALL_ENDED only).
 */
model CallHistory {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// HOST of the call — replaces the old callerId field (caller_id → initiator_id).
  initiatorId      String        @map("initiator_id") @db.Uuid
  callType         CallType      @map("call_type")
  provider         CallProvider  @map("provider")
  duration         Int? // seconds (nullable if missed)
  status           CallStatus
  endReason        String?       @map("end_reason") @db.VarChar(50)
  conversationId   String?       @map("conversation_id") @db.Uuid
  dailyRoomName    String?       @map("daily_room_name") @db.VarChar(100)
  participantCount Int           @default(2) @map("participant_count")

  startedAt DateTime  @map("started_at") @db.Timestamptz
  endedAt   DateTime? @map("ended_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  // [DECOUPLED - Phase 2.2]: Remove physical relations to User and Conversation
  participants CallParticipant[]

  // Feed by initiator (calls I made)
  @@index([initiatorId, deletedAt, startedAt(sort: Desc), id], name: "idx_call_history_initiator_feed")
  // Conversation feed
  @@index([conversationId, deletedAt, startedAt(sort: Desc)], name: "idx_call_history_conversation_feed")
  // Analytics: by time
  @@index([startedAt], name: "idx_call_history_time_range")
  // Analytics: by call type
  @@index([callType, startedAt], name: "idx_call_history_type_analytics")
  @@map("call_history")
}

/**
 * Model: CallParticipant [NEW — Phase B]
 * Tracks every participant in each call (HOST + all MEMBERs).
 * Enables group call history, missed-call badge per user, and role-based queries.
 */
model CallParticipant {
  id       String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  callId   String                @map("call_id") @db.Uuid
  userId   String                @map("user_id") @db.Uuid
  role     CallParticipantRole   @map("role")
  status   CallParticipantStatus @map("status")
  /// Schema-ready. MVP: always null. Future: kick feature.
  kickedBy String?               @map("kicked_by") @db.Uuid

  joinedAt DateTime? @map("joined_at") @db.Timestamptz
  leftAt   DateTime? @map("left_at") @db.Timestamptz
  duration Int? // seconds this participant was in call

  callHistory CallHistory @relation(fields: [callId], references: [id], onDelete: Cascade)
  // [DECOUPLED - Phase 2.2]: Remove physical relations to User
  // user        User        @relation("CallParticipations", fields: [userId], references: [id])
  // kicker      User?       @relation("KickedParticipants", fields: [kickedBy], references: [id])

  @@unique([callId, userId])
  @@index([userId, status], name: "idx_call_participant_user_status") // missed-calls badge
  @@index([userId, role, status], name: "idx_call_participant_user_role_status") // outgoing/incoming
  @@index([callId], name: "idx_call_participant_call")
  @@map("call_participants")
}

