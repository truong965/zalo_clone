/**
 * Model: SearchQuery
 * Tracks search queries for analytics, trending topics, and ranking optimization.
 * Used in Phase 3 of Search Engine Module implementation.
 * Helps understand user search behavior and optimize search results.
 */
model SearchQuery {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // User & Context
  userId String @map("user_id") @db.Uuid

  // Search Parameters
  keyword    String @db.VarChar(255)
  searchType String @map("search_type") @db.VarChar(50) // GLOBAL, CONVERSATION, CONTACT, MEDIA
  filters    Json?  @db.JsonB // Additional filters (messageType, dateRange, etc.)

  // Results & Performance
  resultCount     Int @default(0) @map("result_count")
  executionTimeMs Int @map("execution_time_ms")

  // User Interaction
  clickedResultId String?   @map("clicked_result_id") @db.VarChar(255) // Which result user clicked
  clickedAt       DateTime? @map("clicked_at") @db.Timestamptz

  // Tracking
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([keyword, searchType])
  @@index([createdAt(sort: Desc)])
  @@index([searchType, resultCount])
  @@map("search_queries")
}

// ============================================================================
// 17. REMINDER MODULE (PHASE 4)
// ============================================================================

/**
 * Model: Reminder
 * User-scoped reminders optionally linked to a conversation or message.
 * Triggered via PostgreSQL polling + @Cron scheduler; pushes Socket.IO notification.
 *
 * States:
 *   PENDING:   isTriggered=false, isCompleted=false  → waiting for remindAt
 *   TRIGGERED: isTriggered=true,  isCompleted=false  → fired, awaiting user ack
 *   COMPLETED: isTriggered=true,  isCompleted=true   → user acknowledged/dismissed
 */
model Reminder {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  messageId      BigInt?  @map("message_id")

  content        String   @db.VarChar(500)
  remindAt       DateTime @map("remind_at") @db.Timestamptz

  isTriggered    Boolean   @default(false) @map("is_triggered")
  triggeredAt    DateTime? @map("triggered_at") @db.Timestamptz
  isCompleted    Boolean   @default(false) @map("is_completed")
  completedAt    DateTime? @map("completed_at") @db.Timestamptz

  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message?      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([isTriggered, isCompleted, remindAt(sort: Asc)], map: "idx_reminder_pending_poll")
  @@index([userId, isCompleted, remindAt])
  @@map("reminders")
}

// ============================================================================
// 18. ADMIN PANEL — DAILY STATS (PHASE 0)
// ============================================================================

/**
 * Model: DailyStats
 *
 * Pre-aggregated daily statistics computed by a nightly cronjob (00:05 ICT).
 * Used by admin dashboard time-series charts. One row per calendar day.
 *
 * NOTE: Real-time KPI (totalUsers, onlineUsers, messagesToday) come from Redis counters.
 * This table stores historical aggregates for charts — not queried in hot path.
 */
model DailyStats {
  date DateTime @db.Date // Calendar day (YYYY-MM-DD), used as PK

  // User Activity
  newUsers    Int @default(0) @map("new_users")    // Users registered this day
  activeUsers Int @default(0) @map("active_users") // Users who sent ≥1 message

  // Messages
  messagesTotal  Int  @default(0) @map("messages_total")
  messagesByType Json @default("{}") @map("messages_by_type") @db.JsonB // { TEXT: N, IMAGE: N, ... }

  // Calls
  callsTotal      Int  @default(0) @map("calls_total")
  callsByType     Json @default("{}") @map("calls_by_type") @db.JsonB     // { VOICE: N, VIDEO: N }
  callsByStatus   Json @default("{}") @map("calls_by_status") @db.JsonB   // { COMPLETED: N, MISSED: N, ... }
  callAvgDuration Int  @default(0) @map("call_avg_duration")              // Average seconds (COMPLETED only)

  // Media
  mediaUploads Int    @default(0) @map("media_uploads")
  mediaBytes   BigInt @default(0) @map("media_bytes") // Total bytes uploaded

  @@id([date])
  @@map("daily_stats")
}
